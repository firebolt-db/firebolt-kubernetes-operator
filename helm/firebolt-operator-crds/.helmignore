# Patterns to ignore when building Helm packages.
# Matched against the relative path of files in the chart directory.

# Common VCS / editor / OS cruft
.git/
.gitignore
.DS_Store
*.swp
*.bak
*.tmp
*.orig

# JSON schemas are generated into this chart dir by `make manifests` and are
# kept in the repo for IDE / kubeconform validation, but they are NOT needed
# at install time. They keep full descriptions (~2.2 MB) and would blow the
# Helm release Secret's ~1 MB cap on their own -- so they ship out even though
# the CRD templates are now description-slimmed (scripts/strip-crd-descriptions.py).
# Keep them on disk, ship them out. See KNOWN_ISSUES.md (release-Secret size).
json-schema/

# helm-docs source template; the rendered README.md is shipped instead.
README.md.gotmpl
