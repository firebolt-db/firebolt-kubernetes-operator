# Default image references for the "dev" build variant. This is the implicit
# default — picked up by operator builds and the E2E suite when no extra Go
# build tag is set (i.e. `make build` / `make test-e2e` with no
# IMAGE_VARIANT). The "latest" variant must be opted into with
# `IMAGE_VARIANT=latest` (which adds the `latest` build tag); once the
# engine/metadata `:latest` GHCR aliases and the auto-PR that maintains
# `defaults.latest.env` are in place, flip the default back to "latest".
# See docs-internal/SDLC.md "Default image bumps" for the full rules.
#
# Convention for the dev variant:
#   - ENGINE_TAG / METADATA_TAG track the mutable `:dev` aliases on the
#     engine/metadata GHCR packages (release-flavored dev-branch builds —
#     NOT debug builds). A regression on `:dev` falls over in CI before a
#     partner pulling `:dev` sees it.
#   - Mutable `:dev` means `scripts/load-e2e-images.sh` MUST `docker pull`
#     on every run rather than reusing a stale local cache; the script
#     enforces that.
#   - There is no longer a separate "upgrade-target" tag. The image-switch
#     specs flip the pod template to a synthetic tag (`<current>-uptest`)
#     that the E2E suite materialises by re-tagging the already-loaded
#     image inside each kind node's containerd — see
#     test/e2e/e2e_suite_test.go's SynchronizedBeforeSuite.

ENGINE_IMAGE=ghcr.io/firebolt-db/engine
ENGINE_TAG=dev
METADATA_IMAGE=ghcr.io/firebolt-db/metadata
METADATA_TAG=dev
POSTGRES_IMAGE=postgres:16-alpine
ENVOY_IMAGE=envoyproxy/envoy
ENVOY_TAG=v1.37.2
CURL_IMAGE=curlimages/curl:latest
