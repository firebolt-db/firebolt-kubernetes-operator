# Default image references for the "dev" build variant. This is the implicit
# default — picked up by operator builds and the E2E suite when no extra Go
# build tag is set (i.e. `make build` / `make test-e2e` with no
# IMAGE_VARIANT). The "latest" variant must be opted into with
# `IMAGE_VARIANT=latest` (which adds the `latest` build tag); once the
# engine/metadata `:latest` GHCR aliases and the auto-PR that maintains
# `defaults.latest.env` are in place, flip the default back to "latest".
# See docs/SDLC.md "Default image bumps" for the full rules.
#
# Convention for the dev variant:
#   - The "current" side of the upgrade test is the mutable `:dev` alias —
#     the only mutable alias currently published on the engine/metadata
#     GHCR packages — so a regression on `:dev` falls over in CI before a
#     partner pulling `:dev` sees it. Once `:latest` is also published,
#     flip ENGINE_TAG / METADATA_TAG here to `latest` so the dev variant
#     exercises the full mutable `latest → dev` upgrade path partners
#     would walk.
#   - The "upgrade-target" side, ENGINE_NEW_TAG / METADATA_NEW_TAG,
#     mirrors the pinned values in `defaults.latest.env`. That keeps the
#     suite's `ENGINE_TAG != ENGINE_NEW_TAG` startup guard satisfied
#     (`dev` != a pinned build tag) and ensures both variants exercise
#     the same upgrade target. The stable-release auto-PR that bumps
#     `defaults.latest.env` must mirror its `_NEW_TAG` values into this
#     file at the same time.
#   - Mutable `:dev` on the current side means
#     `scripts/load-e2e-images.sh` MUST `docker pull` on every run rather
#     than reusing a stale local cache; that is enforced inside the
#     script.

ENGINE_IMAGE=ghcr.io/firebolt-db/engine
ENGINE_TAG=dev
ENGINE_NEW_TAG=debug-4.32.0-pre.0.20260505103729.c1bdd880cb63
METADATA_IMAGE=ghcr.io/firebolt-db/metadata
METADATA_TAG=dev
METADATA_NEW_TAG=c1bdd880cb63
POSTGRES_IMAGE=postgres:16-alpine
ENVOY_IMAGE=envoyproxy/envoy
ENVOY_TAG=v1.37.2
CURL_IMAGE=curlimages/curl:latest
