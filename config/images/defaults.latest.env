# Default image references for the "latest" build variant. This is the
# implicit default: it ships in the operator image and the Helm chart, and is
# picked up by `make build` / `make docker-build` / `make test-e2e` when
# IMAGE_VARIANT is unset (the `latest` Go build tag is on by default). The
# "dev" variant (defaults.dev.env) must be opted into with `IMAGE_VARIANT=dev`.
#
# This file is rewritten by an automated PR whenever a new stable engine or
# metadata release is published; the PR runs the full unit and E2E suite so a
# bump that breaks the operator's contract surfaces before merge.
#
# Convention when bumping engine/metadata builds:
#   - ENGINE_TAG MUST be a release-* tag (not a debug- build); the E2E
#     suite operates on release images.
#   - METADATA_TAG MUST also carry the release-/debug- prefix matching
#     the ENGINE_TAG flavor so the two pulls reference the same flavor
#     of build (and so the autobump pipeline can lockstep them).
#   - There is no longer a separate "upgrade-target" tag. The image-switch
#     specs flip the pod template to a synthetic tag (`<current>-uptest`)
#     that the E2E suite materialises by re-tagging the already-loaded
#     image inside each kind node's containerd — see
#     test/e2e/e2e_suite_test.go's SynchronizedBeforeSuite.

ENGINE_IMAGE=ghcr.io/firebolt-db/engine
ENGINE_TAG=release-5.0.1-0.20260622084213.3ef06de4e9aa
METADATA_IMAGE=ghcr.io/firebolt-db/metadata
METADATA_TAG=release-5.0.1-0.20260622084213.3ef06de4e9aa
POSTGRES_IMAGE=postgres:16-alpine
ENVOY_IMAGE=envoyproxy/envoy
ENVOY_TAG=v1.37.2
CURL_IMAGE=curlimages/curl:latest
# Optional engine web UI sidecar (engine spec/class `uiSidecar: true`), injected as
# the operator-owned `engine-web` container. Like CURL it is a utility image
# tracked at the mutable `:latest` alias for now.
ENGINE_WEB_IMAGE=ghcr.io/firebolt-db/firebolt-core-ui
ENGINE_WEB_TAG=latest
