# Default image references for the "latest" build variant. Opt-in: picked up
# by operator builds and the E2E suite when `IMAGE_VARIANT=latest` (which
# adds the `latest` Go build tag). Until the engine/metadata `:latest` GHCR
# aliases — and the auto-PR that bumps this file off them — are in place,
# the project default is the "dev" variant; once they land, flip the
# default back so this file is what ships in the operator image and the
# Helm chart.
# See docs/SDLC.md "Default image bumps" and README.md "Bumping Default
# Image Versions" for the full rules.
#
# This file is rewritten by an automated PR whenever a new stable engine or
# metadata release is published; the PR runs the full unit and E2E suite so a
# bump that breaks the operator's contract surfaces before merge.
#
# Convention when bumping engine/metadata builds:
#   - ENGINE_TAG and ENGINE_NEW_TAG MUST share the same <timestamp>.<sha> build
#     and differ ONLY by the release-/debug- prefix. The "switch image without
#     downtime" E2E test flips between them, so identical underlying builds keep
#     the test exercising the operator's blue/green logic, not version drift.
#   - METADATA_TAG tracks the same build (no release-/debug- prefix).
#   - METADATA_NEW_TAG is the short SHA (last 12 chars) of the same build.
#   - The E2E suite fails fast if ENGINE_TAG == ENGINE_NEW_TAG.
#   - The auto-PR MUST mirror the new ENGINE_NEW_TAG / METADATA_NEW_TAG
#     values into `defaults.dev.env` so both variants exercise the same
#     upgrade target. (defaults.dev.env's "current"-side tags are
#     mutable aliases — currently `:dev` — and don't need to be
#     bumped.)

ENGINE_IMAGE=ghcr.io/firebolt-db/engine
ENGINE_TAG=release-4.32.0-pre.0.20260511124051.ecc66cbe7114
ENGINE_NEW_TAG=debug-4.32.0-pre.0.20260511124051.ecc66cbe7114
METADATA_IMAGE=ghcr.io/firebolt-db/metadata
METADATA_TAG=4.32.0-pre.0.20260511124051.ecc66cbe7114
METADATA_NEW_TAG=ecc66cbe7114
POSTGRES_IMAGE=postgres:16-alpine
ENVOY_IMAGE=envoyproxy/envoy
ENVOY_TAG=v1.37.2
CURL_IMAGE=curlimages/curl:latest
